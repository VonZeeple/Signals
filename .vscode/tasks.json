{
  "version": "2.0.0",
  "tasks": [{
    "label": "Build (Debug)",
    "group": { "kind": "build", "isDefault": true },
    "presentation": { "reveal": "silent" },
    "problemMatcher": "$msCompile",

    "type": "process",
    "command": "dotnet",
    "args": [ "build","signals.csproj" , "-c", "Debug" ]
  },{
    "label": "Build (Release)",
    "group": "build",
    "presentation": { "reveal": "silent" },
    "problemMatcher": "$msCompile",

    "type": "process",
    "command": "dotnet",
    "args": [ "build", "-c", "Release" ]
  },{
    "label": "Package Mod (Debug Zip)",
    "presentation": { "reveal": "always" },
    "type": "process",
    "command": "py",
    "args": ["-3", "scripts/package_mod.py"]
  }]
}